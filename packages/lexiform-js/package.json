{
  "name": "lexiform",
  "version": "1.0.5",
  "description": "Developer-first DSL for building and validating cross-platform forms.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./lexiform.js": "./dist/lexiform.js",
    "./lexiform.wasm": "./dist/lexiform.wasm",
    "./client": {
      "types": "./dist/client.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:wasm": "cd ../../ && npm run build:wasm",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --minify",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run"
  },
  "keywords": [
    "Lexiform",
    "dsl",
    "forms",
    "compiler",
    "validation",
    "webassembly",
    "wasm",
    "react",
    "typescript"
  ],
  "author": "Lexiform Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/taaha-0548/Lexiform.git"
  },
  "bugs": {
    "url": "https://github.com/taaha-0548/Lexiform/issues"
  },
  "homepage": "https://github.com/taaha-0548/Lexiform#readme",
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsup": "^8.0.0",
    "vitest": "^1.0.0",
    "@types/react": "^18.0.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  }
}
