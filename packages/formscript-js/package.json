{
  "name": "lexiform",
  "version": "1.0.0",
  "description": "Developer-first DSL for building and validating cross-platform forms.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src/wasm"
  ],
  "scripts": {
    "build:wasm": "cd ../../ && npm run build:wasm",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --minify",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run"
  },
  "keywords": [
    "formscript",
    "dsl",
    "forms",
    "compiler",
    "validation"
  ],
  "author": "FormScript Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/lexiform.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/lexiform/issues"
  },
  "homepage": "https://github.com/your-username/lexiform#readme",
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsup": "^8.0.0",
    "vitest": "^1.0.0",
    "@types/react": "^18.0.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  }
}
